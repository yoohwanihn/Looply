# =============================================
# 사내 SNS 플랫폼 - 환경변수 예시
# 실제 사용 시 .env 파일로 복사 후 값 변경
# =============================================

# PostgreSQL (메인 DB)
POSTGRES_DB=sns_db
POSTGRES_USER=sns_user
POSTGRES_PASSWORD=changeme_db_password

# Redis
REDIS_PASSWORD=changeme_redis_password

# JWT (Spring Security + JJWT)
JWT_SECRET=changeme_jwt_secret_must_be_at_least_256bits_long_string_here
JWT_ACCESS_EXPIRY=3600000
JWT_REFRESH_EXPIRY=604800000

# Spring Boot
SPRING_PROFILES_ACTIVE=dev

# SonarQube (인프라 프로파일 사용 시)
SONAR_JDBC_PASSWORD=changeme_sonar_password

# Jenkins (인프라 프로파일 사용 시)
JENKINS_ADMIN_PASSWORD=changeme_jenkins_password
